{
  "name": "zipcatcher",
  "version": "0.1.2",
  "description": "Track aircraft transiting the Sun and Moon",
  "author": "Aerodite, Inc.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.zipcatcher.app",
    "productName": "Zipcatcher",
    "copyright": "Copyright © 2025 Zipcatcher",
    "directories": {
      "buildResources": "assets",
      "output": "../dist-electron"
    },
    "extraResources": [
      {
        "from": "zipcatcher-server",
        "to": "zipcatcher-server"
      },
      {
        "from": "node_modules/ffmpeg-static/ffmpeg",
        "to": "ffmpeg"
      },
      {
        "from": "../static",
        "to": "static",
        "filter": [
          "**/*",
          "!captures/**",
          "!captures"
        ]
      },
      {
        "from": "../templates",
        "to": "templates"
      },
      {
        "from": "../src",
        "to": "src"
      },
      {
        "from": "../app.py",
        "to": "app.py"
      },
      {
        "from": "../de421.bsp",
        "to": "de421.bsp"
      },
      {
        "from": "../README.md",
        "to": "docs/README.md"
      },
      {
        "from": "../SETUP.md",
        "to": "docs/SETUP.md"
      },
      {
        "from": "../QUICKSTART.md",
        "to": "docs/QUICKSTART.md"
      },
      {
        "from": "../docs/Zipcatcher-article.pdf",
        "to": "docs/Zipcatcher-article.pdf"
      },
      {
        "from": "../docs/transit_capture_position_paper.pdf",
        "to": "docs/transit_capture_position_paper.pdf"
      },
      {
        "from": "../docs/TELESCOPE_GUIDE.md",
        "to": "docs/TELESCOPE_GUIDE.md"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "wizard.html",
      "assets/**"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "darkModeSupport": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "title": "Zipcatcher",
      "background": "assets/dmg-background.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zipcatcher",
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Science"
    }
  },
  "devDependencies": {
    "electron": "^39.8.7",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
